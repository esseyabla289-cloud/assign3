# TODO: Add rule to aggregate counts using workflow/scripts/aggregate_counts.py
rule aggregate_counts:
    input:
        counts=expand("../results/counts/{sample}.counts.txt", sample=sample)
    output:
        "../results/counts/count_matrix.tsv"
    log:
        "../logs/aggregate_counts.log"
    script:
        "scripts/aggregate_counts.py"

