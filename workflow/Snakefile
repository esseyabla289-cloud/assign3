# TASK 6: DESeq2 Preparation  
# ============================================================================

# TODO: Add rule to prepare DESeq2 dataset using workflow/scripts/prepare_deseq2.R

rule ea_deseq2:
    input:
        counts= "../results/counts/count_matrix.tsv",
        metadata= "../config/samples.tsv"
    output:
        rds="../results/deseq2/deseq2_dataset.rds",
        normalized="../results/deseq2/normalized_counts.tsv"
    params:
        min_counts=10
    log:
        "../logs/prepare_deseq2.log"
    script:
        "scripts/prepare_deseq2.R"
